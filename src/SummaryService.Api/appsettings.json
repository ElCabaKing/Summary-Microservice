{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.SemanticKernel": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
  "AI": {
    "DefaultProvider": "groq",
    "DefaultModel": "llama-3.3-70b-versatile",
    "Providers": {
      "groq": {
        "Type": "OpenAICompatible",
        "Endpoint": "https://api.groq.com/openai/v1",
        "ApiKey": "GROK PLACEGOLDER",
        "Models": [
          "llama-3.3-70b-versatile",
          "llama-3.1-8b-instant",
          "mixtral-8x7b-32768",
          "gemma2-9b-it"
        ]
      },
      "gemini": {
        "Type": "OpenAICompatible",
        "Endpoint": "https://generativelanguage.googleapis.com/v1beta/openai",
        "ApiKey": "GEMINI PLACEHOLDER",
        "Models": [
          "Gemini 2.5 Flash"
        ]
      }
    }
  },
  "Summary": {
    "MaxFileSizeMb": 15,
    "MaxTokens": 2048
  },
  "Chunking": {
    "MaxChunkTokens": 6000,
    "OverlapTokens": 300,
    "MaxChunks": 100
  },
  "OCR": {
    "MaxPages": 100,
    "Dpi": 300,
    "TimeoutSeconds": 60
  }
}