{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.SemanticKernel": "Warning"
      }
    }
  },
  "AllowedHosts": "*",
 
  "Summary": {
    "MaxFileSizeMb": 15,
    "MaxTokens": 2048
  },
  "Chunking": {
    "MaxChunkTokens": 6000,
    "OverlapTokens": 300,
    "MaxChunks": 100
  },
  "OCR": {
    "MaxPages": 100,
    "Dpi": 300,
    "TimeoutSeconds": 60
  }
}
